NODE_ENV=development
HOST=127.0.0.1
PORT=4000
CORS_ORIGIN=http://localhost:5173

# SQLite database path. Relative paths are resolved from /backend.
DB_FILE=./data/app.db

# Future provider settings.
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
ANTIGRAVITY_CLI_COMMAND=agy

# Keep provider credential endpoints localhost-only unless this is a trusted private deployment.
ALLOW_REMOTE_PROVIDER_AUTH=false
# OAuth Provider Settings
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
# Callback URL should match: http://localhost:4000/api/providers/[provider-id]/callback
