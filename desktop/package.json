{
  "name": "role-ai-brainstorm-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for the role-based AI brainstorming workspace.",
  "main": "main.cjs",
  "scripts": {
    "build:renderer": "npm --prefix ../frontend run build",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder --win nsis",
    "start": "npm run build:renderer && electron .",
    "smoke": "npm run build:renderer && node scripts/smoke.cjs"
  },
  "build": {
    "appId": "com.roleaibrainstorm.workspace",
    "productName": "Role AI Brainstorm Workspace",
    "directories": {
      "output": "artifacts"
    },
    "asar": false,
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/src",
        "to": "backend/src"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.12"
  }
}
